{
    "buildCommand": "npx expo export --platform web",
    "outputDirectory": "dist",
    "installCommand": "npm install",
    "framework": null,
    "public": true,
    "rewrites": [
        {
            "source": "/pricing",
            "destination": "https://prepassist-landing-vamsis-projects-4d71922c.vercel.app/pricing"
        },
        {
            "source": "/admin",
            "destination": "https://prepassist-dashboard.vercel.app/"
        },
        {
            "source": "/dashboard",
            "destination": "https://prepassist-dashboard.vercel.app/dashboard"
        },
        {
            "source": "/dashboard/:path*",
            "destination": "https://prepassist-dashboard.vercel.app/dashboard/:path*"
        },
        {
            "source": "/_next/:path*",
            "destination": "https://prepassist-dashboard.vercel.app/_next/:path*"
        },
        {
            "source": "/api/:path*",
            "destination": "https://prepassist-dashboard.vercel.app/api/:path*"
        },
        {
            "source": "/prepassist-logo.png",
            "destination": "https://prepassist-dashboard.vercel.app/prepassist-logo.png"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=0, must-revalidate"
                }
            ]
        },
        {
            "source": "/_expo/static/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ]
}
